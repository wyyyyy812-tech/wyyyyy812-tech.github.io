<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>

<!-- Theme Toggle -->
<script>
  const localTheme = typeof localStorage !== "undefined" && localStorage.getItem("site-theme");
  let theme = localTheme || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  document.documentElement.setAttribute("data-theme", theme);
  function switchTheme() { theme = theme === "dark" ? "light" : "dark"; document.documentElement.setAttribute("data-theme", theme); localStorage.setItem("site-theme", theme); }
  function useToggle() { const t = document.startViewTransition && !window.matchMedia("(prefers-reduced-motion: reduce)").matches; if (!t) { switchTheme(); return; } document.startViewTransition(switchTheme); }
  function toggleDrawer() { document.getElementById('drawer').classList.toggle('open'); document.getElementById('sidebarOverlay').classList.toggle('show'); }
</script>

<!-- AOS -->
<script>AOS.init({ duration: 800, once: true });</script>

<!-- Fireworks -->
<canvas id="fireworks" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; pointer-events: none; z-index: 32767;"></canvas>
<script>
  if (!window.hasOwnProperty("ontouchstart")) {
    const canvas = document.getElementById('fireworks'); const ctx = canvas.getContext('2d');
    canvas.width = window.innerWidth; canvas.height = window.innerHeight;
    window.addEventListener('resize', () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; });
    class Particle { constructor(x,y,c){this.x=x;this.y=y;this.color=c;const a=Math.random()*Math.PI*2,s=Math.random()*4+2;this.vx=Math.cos(a)*s;this.vy=Math.sin(a)*s;this.life=1;this.decay=Math.random()*0.025+0.015;this.size=Math.random()*3+1;} update(){this.x+=this.vx;this.y+=this.vy;this.vy+=0.03;this.life-=this.decay;} draw(){ctx.save();ctx.globalAlpha=this.life;ctx.fillStyle=this.color;ctx.beginPath();ctx.arc(this.x,this.y,this.size,0,Math.PI*2);ctx.fill();ctx.restore();} }
    let particles = []; const colors = ['#ff7675','#fd79a8','#6c5ce7','#a29bfe','#00cec9','#0984e3','#ffeaa7','#fdcb6e','#55efc4','#e17055'];
    document.addEventListener('click', e => { if(e.target.closest('a,button,input,.nexmoe-drawer,#waifu,.aplayer'))return; for(let i=0;i<30;i++) particles.push(new Particle(e.clientX,e.clientY,colors[Math.floor(Math.random()*colors.length)])); });
    (function animate(){if(particles.length>0){ctx.clearRect(0,0,canvas.width,canvas.height);particles.forEach(p=>{p.update();p.draw();});particles=particles.filter(p=>p.life>0);if(particles.length===0)ctx.clearRect(0,0,canvas.width,canvas.height);}requestAnimationFrame(animate);})();
  }
</script>

<!-- Code Block Enhancement (reimu style) -->
<div id="copy-tooltip"></div>
<script>
(function() {
  // Wrap pre in scrollable area
  document.querySelectorAll('figure.highlight pre').forEach(function(pre) {
    if (!pre.parentNode.classList.contains('code-area') && !pre.parentNode.classList.contains('gutter')) {
      var div = document.createElement('div');
      div.className = 'code-area';
      pre.parentNode.insertBefore(div, pre);
      div.appendChild(pre);
    }
  });

  // Insert header bar
  document.querySelectorAll('figure.highlight').forEach(function(fig) {
    if (fig.querySelector('.code-figcaption')) return;
    var lang = fig.className.replace('highlight', '').trim().toUpperCase();
    var header = document.createElement('div');
    header.className = 'code-figcaption';
    header.innerHTML =
      '<div class="code-left-wrap"><div class="code-decoration"></div><div class="code-lang">' + lang + '</div></div>' +
      '<div class="code-right-wrap"><button class="code-copy-btn" title="複製"><i class="fa-solid fa-copy"></i></button></div>';
    fig.insertBefore(header, fig.firstChild);
  });

  // Copy functionality
  document.querySelectorAll('.code-copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var fig = btn.closest('figure.highlight');
      var code = fig.querySelector('td.code pre') || fig.querySelector('.code-area pre');
      if (!code) return;
      var text = code.textContent;
      navigator.clipboard.writeText(text).then(function() {
        btn.innerHTML = '<i class="fa-solid fa-check"></i>';
        btn.classList.add('copied');
        var tooltip = document.getElementById('copy-tooltip');
        tooltip.textContent = '複製成功！';
        tooltip.style.opacity = '1';
        setTimeout(function() {
          tooltip.style.opacity = '0';
          btn.innerHTML = '<i class="fa-solid fa-copy"></i>';
          btn.classList.remove('copied');
        }, 1500);
      });
    });
  });
})();
</script>

