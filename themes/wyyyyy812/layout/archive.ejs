<div class="page-header" data-aos="fade-down">
  <h1><i class="fa-solid fa-box-archive"></i> 文章歸檔</h1>
  <p>共 <%= site.posts.length %> 篇文章</p>
</div>

<% if (site.categories.length > 0) { %>
<div class="archive-section" data-aos="fade-up">
  <h2><i class="fa-solid fa-folder"></i> 分類</h2>
  <div class="archive-tags">
    <% site.categories.forEach(function(cat) { %>
    <a href="<%- url_for(cat.path) %>" class="archive-tag-item">
      <span><%= cat.name %></span>
      <span class="tag-count"><%= cat.posts.length %></span>
    </a>
    <% }); %>
  </div>
</div>
<% } %>

<% if (site.tags.length > 0) { %>
<div class="archive-section" data-aos="fade-up">
  <h2><i class="fa-solid fa-tags"></i> 標籤</h2>
  <div class="archive-tags">
    <% site.tags.forEach(function(tag) { %>
    <a href="<%- url_for(tag.path) %>" class="archive-tag-item">
      <span><%= tag.name %></span>
      <span class="tag-count"><%= tag.posts.length %></span>
    </a>
    <% }); %>
  </div>
</div>
<% } %>

<% if (site.posts.length > 0) { %>
<div class="archive-section" data-aos="fade-up">
  <h2><i class="fa-solid fa-clock-rotate-left"></i> 時間線</h2>
</div>
<div class="archive-timeline" data-aos="fade-up">
  <% var currentYear = ''; %>
  <% site.posts.sort('date', -1).forEach(function(post) { %>
    <% var year = date(post.date, 'YYYY'); %>
    <% if (year !== currentYear) { %>
      <% if (currentYear !== '') { %></div><% } %>
      <div class="timeline-year">
        <h2><%= year %></h2>
      <% currentYear = year; %>
    <% } %>
    <div class="timeline-item">
      <div class="timeline-dot"></div>
      <div class="timeline-content">
        <span class="timeline-date"><%= date(post.date, 'MM-DD') %></span>
        <a href="<%- url_for(post.path) %>" class="timeline-title"><%= post.title %></a>
      </div>
    </div>
  <% }); %>
  <% if (currentYear !== '') { %></div><% } %>
</div>
<% } else { %>
<div class="empty-state" data-aos="fade-up">
  <i class="fa-solid fa-feather-pointed"></i>
  <p>更多文章即將推出，敬請期待！</p>
</div>
<% } %>
